# Copy this file to .env.local and fill with your own Supabase project credentials.
# Create a free project at https://supabase.com to get them.

# The Supabase URL: https://<project-ref>.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# The anon (public) key for your Supabase project (Settings → API → Project API keys).
# Safe to ship in client builds, but DO NOT commit your real one — keep it in .env.local.
VITE_SUPABASE_ANON_KEY=your-anon-key-here
